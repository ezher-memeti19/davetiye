PORT=3000

# Dropbox OAuth 2 credentials (server-side only)
DROPBOX_CLIENT_ID=your_dropbox_app_client_id
DROPBOX_CLIENT_SECRET=your_dropbox_app_client_secret
DROPBOX_REFRESH_TOKEN=your_dropbox_refresh_token

# Private destination root folder inside Dropbox
DROPBOX_UPLOAD_ROOT=/Wedding-Guest-Uploads

# Upload constraints
MAX_UPLOAD_FILE_SIZE_BYTES=10485760
MAX_UPLOAD_FILE_COUNT=10
